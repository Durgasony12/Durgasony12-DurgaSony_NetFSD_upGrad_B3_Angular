@using WebApplication1.Models;
@model Product
<h1> Edit product</h1>

<form method="POST" asp-action="Edit">
    <div class="form-group">
        <label asp-for="PID" class="form-label"></label>
        <input asp-for="PID" class="form-control" readonly/>
    </div>
    <div class="form-group">
        <label asp-for="Pname" class="form-label"></label>
        <input asp-for="Pname" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Price" class="form-label"></label>
        <input asp-for="Price" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Brand" class="form-label"></label>
        <input asp-for="Brand" class="form-control" />
    </div>
    <button type="submit" class="btn btn-success">Edit</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>