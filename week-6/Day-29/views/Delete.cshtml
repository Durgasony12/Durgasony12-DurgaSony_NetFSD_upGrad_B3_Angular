@using WebApplication1.Models;
@model Product
<h1> Delete product</h1>

@if (Model == null)
{
    <p>product details are not available</p>
}
else
{
    <div>
        Product ID : @Model.PID <br />
        Product Pname : @Model.Pname <br />
        Product Price: @Model.Price <br />
        Product Brand: @Model.Brand
    </div>
}
    

<form asp-action="delete" method="post">
    <input type="hidden" name="id" value="@Model.PID" />
    <p>Do you want to delete this employee details?</p>
    <button type="submit" class="btn btn-success">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>